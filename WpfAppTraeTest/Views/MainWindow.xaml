<Window x:Class="WpfAppTraeTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppTraeTest.Views"
        xmlns:vm="clr-namespace:WpfAppTraeTest.ViewModels"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#F5F7FA"
        Foreground="#2D3748"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- 明亮风格颜色 -->
        <SolidColorBrush x:Key="IndustrialDark" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="IndustrialPanel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="IndustrialBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="IndustrialAccent" Color="#3182CE"/>
        <SolidColorBrush x:Key="IndustrialGreen" Color="#38A169"/>
        <SolidColorBrush x:Key="IndustrialRed" Color="#E53E3E"/>
        <SolidColorBrush x:Key="IndustrialYellow" Color="#D69E2E"/>
        <SolidColorBrush x:Key="IndustrialText" Color="#2D3748"/>
        <SolidColorBrush x:Key="IndustrialTextDim" Color="#718096"/>
        <SolidColorBrush x:Key="IndustrialMetal" Color="#A0AEC0"/>

        <!-- 清新边框 -->
        <LinearGradientBrush x:Key="MetalBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E2E8F0" Offset="0"/>
            <GradientStop Color="#CBD5E0" Offset="0.5"/>
            <GradientStop Color="#E2E8F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- 标题栏样式 -->
        <Style x:Key="HeaderPanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <!-- 相机容器 - 明亮风格 -->
        <Style x:Key="CameraContainer" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.1" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 选中状态的相机容器 -->
        <Style x:Key="CameraContainerActive" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3182CE"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="#3182CE"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 侧面板 -->
        <Style x:Key="SidePanel" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- 清新按钮基础样式 -->
        <Style x:Key="IndustrialBtn" TargetType="Button">
            <Setter Property="Background" Value="#EDF2F7"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="BorderBrush" Value="#CBD5E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CBD5E0"/>
                                <Setter Property="BorderBrush" Value="#3182CE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#EDF2F7"/>
                                <Setter Property="Foreground" Value="#A0AEC0"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 启动按钮 - 绿色 -->
        <Style x:Key="StartBtn" TargetType="Button" BasedOn="{StaticResource IndustrialBtn}">
            <Setter Property="Background" Value="#38A169"/>
            <Setter Property="BorderBrush" Value="#38A169"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#48BB78"/>
                                <Setter Property="BorderBrush" Value="#48BB78"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2F855A"/>
                                <Setter Property="BorderBrush" Value="#2F855A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 停止按钮 - 红色 -->
        <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource IndustrialBtn}">
            <Setter Property="Background" Value="#E53E3E"/>
            <Setter Property="BorderBrush" Value="#E53E3E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FC8181"/>
                                <Setter Property="BorderBrush" Value="#FC8181"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C53030"/>
                                <Setter Property="BorderBrush" Value="#C53030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口按钮 -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#2D3748"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 导航按钮 - 普通 -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EDF2F7"/>
                                <Setter Property="Foreground" Value="#3182CE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 导航按钮 - 选中 -->
        <Style x:Key="NavButtonSelected" TargetType="Button">
            <Setter Property="Background" Value="#3182CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4299E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 数据展示面板 -->
        <Style x:Key="DataPanel" TargetType="Border">
            <Setter Property="Background" Value="#252A30"/>
            <Setter Property="BorderBrush" Value="#3A4048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- 状态指示灯 -->
        <Style x:Key="StatusLight" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00C851" BlurRadius="8" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Style="{StaticResource HeaderPanel}" MouseLeftButtonDown="HeaderPanel_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo和标题 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Background="#3182CE" CornerRadius="6" Margin="0,0,12,0">
                        <TextBlock Text="VP" Foreground="White" FontWeight="Bold" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="视觉对位系统" FontSize="18" FontWeight="Bold" Foreground="#2D3748"/>
                        <TextBlock Text="Vision Positioning System" FontSize="11" Foreground="#718096"/>
                    </StackPanel>
                </StackPanel>

                <!-- 系统状态 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="系统状态:" Foreground="#718096" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding SystemStatus}" Foreground="#2D3748" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="节拍:" Foreground="#718096" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="2.45s" Foreground="#38A169" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="_" Style="{StaticResource WindowButton}" Click="MinimizeButton_Click"/>
                    <Button Content="□" Style="{StaticResource WindowButton}" Click="MaximizeButton_Click"/>
                    <Button Content="×" Style="{StaticResource WindowButton}" Foreground="#FF4444" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border x:Name="NavPanel" Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Width="200">
                    <StackPanel Margin="0,16">
                        <Grid Margin="20,0,12,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="功能导航" Foreground="#3182CE" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="btnCollapseNav" Grid.Column="1" Content="◀" Width="24" Height="24" 
                                    Background="#EDF2F7" Foreground="#718096" BorderThickness="0" Cursor="Hand"
                                    Click="CollapseNavButton_Click" FontSize="10"/>
                        </Grid>
                        
                        <Button x:Name="btnCameraStatus" Style="{StaticResource NavButton}" Click="NavButton_Click" Tag="CameraStatus">
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <TextBlock x:Name="iconCamera" Text="📷" FontSize="18" Width="28" TextAlignment="Center"/>
                                <TextBlock x:Name="textCamera" Text="相机状态" FontSize="13" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnCalibration" Style="{StaticResource NavButton}" Click="NavButton_Click" Tag="Calibration">
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <TextBlock x:Name="iconCalibration" Text="⚙️" FontSize="18" Width="28" TextAlignment="Center"/>
                                <TextBlock x:Name="textCalibration" Text="标定功能" FontSize="13" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnParameters" Style="{StaticResource NavButton}" Click="NavButton_Click" Tag="Parameters">
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <TextBlock x:Name="iconParameters" Text="🔧" FontSize="18" Width="28" TextAlignment="Center"/>
                                <TextBlock x:Name="textParameters" Text="参数设置" FontSize="13" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                        
                        <Border Background="#E2E8F0" Height="1" Margin="20,24"/>
                        
                        <Button x:Name="btnHome" Style="{StaticResource NavButtonSelected}" Click="NavButton_Click" Tag="Home">
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <TextBlock x:Name="iconHome" Text="🏠" FontSize="18" Width="28" TextAlignment="Center"/>
                                <TextBlock x:Name="textHome" Text="主界面" FontSize="13" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- 展开按钮（收缩后显示） -->
                <Button x:Name="btnExpandNav" Grid.Column="1" Content="▶" Width="20" Height="60" 
                        Background="#EDF2F7" Foreground="#718096" BorderThickness="0" Cursor="Hand"
                        Click="ExpandNavButton_Click" FontSize="10" Visibility="Collapsed"
                        VerticalAlignment="Center" Margin="2,0,0,0"/>
            </Grid>

            <!-- 主内容区域 - Prism Region -->
            <ContentControl Grid.Column="1" x:Name="MainContentRegion" prism:RegionManager.RegionName="MainContentRegion" Margin="0" Background="#F5F7FA"/>

            <!-- 右侧面板 -->
            <Border Grid.Column="2" Style="{StaticResource SidePanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 系统控制 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="系统控制" Foreground="#3182CE" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="启动" Style="{StaticResource StartBtn}" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="停止" Style="{StaticResource StopBtn}" Margin="4,0,0,0"/>
                                </Grid>
                                <Button Content="自动标定" Style="{StaticResource IndustrialBtn}" Margin="0,8,0,0"/>
                                <Button Content="手动触发" Style="{StaticResource IndustrialBtn}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 对位结果 -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="对位结果" Foreground="#3182CE" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="6" Padding="8,12" Margin="0,0,4,0">
                                        <StackPanel>
                                            <TextBlock Text="ΔX" Foreground="#718096" HorizontalAlignment="Center" FontSize="11"/>
                                            <TextBlock Text="0.012" Foreground="#38A169" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="mm" Foreground="#A0AEC0" HorizontalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="6" Padding="8,12" Margin="4,0">
                                        <StackPanel>
                                            <TextBlock Text="ΔY" Foreground="#718096" HorizontalAlignment="Center" FontSize="11"/>
                                            <TextBlock Text="-0.005" Foreground="#38A169" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="mm" Foreground="#A0AEC0" HorizontalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="6" Padding="8,12" Margin="4,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Δθ" Foreground="#718096" HorizontalAlignment="Center" FontSize="11"/>
                                            <TextBlock Text="0.002" Foreground="#38A169" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="°" Foreground="#A0AEC0" HorizontalAlignment="Center" FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 相机状态 -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="相机状态" Foreground="#3182CE" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>
                                <ListView Background="Transparent" BorderThickness="0" ItemsSource="{Binding Cameras}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                               Foreground="#2D3748" FontSize="12"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#718096" FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 过程日志 -->
                    <StackPanel Grid.Row="3">
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="过程日志" Foreground="#3182CE" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Border Grid.Row="1" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                                    <ListBox ItemsSource="{Binding Logs}" Background="Transparent" Foreground="#718096"
                                             FontFamily="Consolas" FontSize="10" BorderThickness="0" Padding="8"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="VisionPro" Foreground="#718096" FontSize="11"/>
                    <TextBlock Text="9.8 SR1" Foreground="#A0AEC0" FontSize="11" Margin="4,0,0,0"/>
                    <Border Background="#E2E8F0" Width="1" Margin="12,2"/>
                    <TextBlock Text="Engine Ready" Foreground="#38A169" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="OPERATOR" Foreground="#718096" FontSize="11"/>
                    <TextBlock Text="Admin" Foreground="#2D3748" FontSize="11" Margin="6,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="2026-02-28 12:00:00" Foreground="#A0AEC0" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>