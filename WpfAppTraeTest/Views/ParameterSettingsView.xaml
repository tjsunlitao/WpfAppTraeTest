<UserControl x:Class="WpfAppTraeTest.Views.ParameterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F7FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="参数设置" FontSize="20" FontWeight="Bold" Foreground="#3182CE" Margin="0,0,0,16"/>

        <!-- 参数内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 通信参数 -->
                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="通信参数" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="PLC IP地址" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="192.168.1.100" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,12">
                                <TextBlock Text="PLC端口" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="502" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,12">
                                <TextBlock Text="通信协议" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28">
                                    <ComboBoxItem Content="Modbus TCP" IsSelected="True"/>
                                    <ComboBoxItem Content="TCP/IP"/>
                                    <ComboBoxItem Content="Ethernet/IP"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="超时时间 (ms)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="5000" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="重试次数" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="3" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="心跳间隔 (ms)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="1000" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 对位参数 -->
                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="对位参数" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="对位精度 (mm)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="0.05" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,12">
                                <TextBlock Text="最大尝试次数" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="5" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,12">
                                <TextBlock Text="超时时间 (s)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="30" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="旋转中心X (mm)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="250.0" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="旋转中心Y (mm)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="200.0" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="旋转角度 (°)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="0" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 图像参数 -->
                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="图像参数" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                <TextBlock Text="曝光时间 (μs)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="8000" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,12">
                                <TextBlock Text="增益 (dB)" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="0" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,12">
                                <TextBlock Text="白平衡" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28">
                                    <ComboBoxItem Content="自动" IsSelected="True"/>
                                    <ComboBoxItem Content="手动"/>
                                    <ComboBoxItem Content="关闭"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="图像宽度" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="2592" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4" IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="图像高度" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="1944" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4" IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="像素格式" Foreground="#718096" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="Bayer RG8" Background="#FFFFFF" Foreground="#2D3748" BorderBrush="#E2E8F0" Height="28" Padding="8,4" IsReadOnly="True"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="恢复默认" Width="100" Height="36" Margin="0,0,12,0"
                            Background="#EDF2F7" Foreground="#2D3748" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="保存设置" Width="100" Height="36"
                            Background="#3182CE" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>