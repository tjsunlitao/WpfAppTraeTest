<Window x:Class="WpfAppTraeTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppTraeTest.Views"
        xmlns:vm="clr-namespace:WpfAppTraeTest.ViewModels"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#121212"
        Foreground="White"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Modern Dark Theme Styles -->
        <Style x:Key="HeaderPanel" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <Style x:Key="CameraContainer" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="SidePanel" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#007E33"/>
            <Setter Property="BorderBrush" Value="#00C851"/>
        </Style>

        <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
        </Style>
        
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Style="{StaticResource HeaderPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12,18.17L8.83,15L7.42,16.41L12,21L16.59,16.41L15.17,15L12,18.17M12,5.83L15.17,9L16.58,7.59L12,3L7.41,7.59L8.83,9L12,5.83Z" 
                          Fill="#007ACC" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#007ACC"/>
                    <Border Background="#333333" CornerRadius="10" Padding="10,2" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding SystemStatus}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="0" FontFamily="Marlett" Style="{StaticResource WindowButton}" Click="MinimizeButton_Click"/>
                    <Button Content="1" FontFamily="Marlett" Style="{StaticResource WindowButton}" Click="MaximizeButton_Click"/>
                    <Button Content="r" FontFamily="Marlett" Style="{StaticResource WindowButton}" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Camera Display Grid (3x2) -->
            <UniformGrid Columns="3" Rows="2" Margin="10">
                <!-- Camera 1 -->
                <Border Style="{StaticResource CameraContainer}">
                    <Grid>
                        <TextBlock Text="Camera 1 - Top Left" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#AAAAAA" FontSize="12"/>
                        <Grid Background="Black" Margin="0,25,0,0">
                            <TextBlock Text="NO SIGNAL" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Camera 2 -->
                <Border Style="{StaticResource CameraContainer}">
                    <Grid>
                        <TextBlock Text="Camera 2 - Top Right" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#AAAAAA" FontSize="12"/>
                        <Grid Background="Black" Margin="0,25,0,0">
                            <TextBlock Text="NO SIGNAL" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Camera 3 -->
                <Border Style="{StaticResource CameraContainer}">
                    <Grid>
                        <TextBlock Text="Camera 3 - Bottom Left" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#AAAAAA" FontSize="12"/>
                        <Grid Background="Black" Margin="0,25,0,0">
                            <TextBlock Text="NO SIGNAL" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Camera 4 -->
                <Border Style="{StaticResource CameraContainer}">
                    <Grid>
                        <TextBlock Text="Camera 4 - Bottom Right" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#AAAAAA" FontSize="12"/>
                        <Grid Background="Black" Margin="0,25,0,0">
                            <TextBlock Text="NO SIGNAL" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Camera 5 -->
                <Border Style="{StaticResource CameraContainer}">
                    <Grid>
                        <TextBlock Text="Camera 5 - Side View" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#AAAAAA" FontSize="12"/>
                        <Grid Background="Black" Margin="0,25,0,0">
                            <TextBlock Text="NO SIGNAL" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Stats Area -->
                <Border Style="{StaticResource CameraContainer}" BorderBrush="#007ACC" BorderThickness="2">
                    <Grid Background="#252526">
                        <TextBlock Text="Overall Result" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Foreground="#007ACC" FontSize="12" FontWeight="Bold"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="PASS" Foreground="#00C851" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cycle Time: 2.45s" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Control & Results Sidebar -->
            <Border Grid.Column="1" Style="{StaticResource SidePanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="System Control" Foreground="#007ACC" Margin="0,0,0,10" FontWeight="Bold"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="START" Style="{StaticResource StartBtn}" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="STOP" Style="{StaticResource StopBtn}" Margin="5,0,0,0"/>
                        </Grid>
                        <Button Content="AUTO CALIBRATE" Style="{StaticResource ActionBtn}"/>
                        <Button Content="MANUAL TRIGGER" Style="{StaticResource ActionBtn}"/>
                    </StackPanel>

                    <!-- Alignment Results -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="Alignment Data" Foreground="#007ACC" Margin="0,0,0,10" FontWeight="Bold"/>
                        <Border Background="#2D2D2D" CornerRadius="4" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="ΔX" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0.012" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="ΔY" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                    <TextBlock Text="-0.005" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Δθ" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0.002°" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Detailed Camera Info List -->
                    <Grid Grid.Row="2">
                        <ListView Background="Transparent" BorderThickness="0" ItemsSource="{Binding Cameras}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="5,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#888888" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- Event Logs -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Process Log" Foreground="#007ACC" Margin="0,0,0,5" FontWeight="Bold"/>
                        <Border Grid.Row="1" Background="#000000" CornerRadius="4">
                            <ListBox ItemsSource="{Binding Logs}" Background="Transparent" Foreground="#00FF00" FontFamily="Consolas" FontSize="11" BorderThickness="0"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="VisionPro Engine: 9.8 SR1" Foreground="#888888" FontSize="11"/>
                <TextBlock Grid.Column="2" Text="User: Administrator | 2026-02-28 12:00:00" Foreground="#888888" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>